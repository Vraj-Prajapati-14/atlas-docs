# ─── Database ───────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (connection pooler for API)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/atlas?sslmode=require&pgbouncer=true"
# Neon direct connection (Prisma migrations only — bypasses PgBouncer)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/atlas?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────────────────────
# 64-byte hex secret: openssl rand -hex 64
JWT_SECRET="change-me-to-random-64-byte-hex-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
# Cost factor for bcrypt (10 = ~100ms, 12 = ~400ms)
BCRYPT_ROUNDS="10"

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3001"
HOST="0.0.0.0"
LOG_LEVEL="info"
CORS_ORIGIN="http://localhost:3000"

# ─── Redis (BullMQ job queues — optional in dev) ─────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="xxx"
RAZORPAY_WEBHOOK_SECRET="xxx"

# ─── WhatsApp (Meta Business API) ────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN="xxx"
WHATSAPP_PHONE_NUMBER_ID="xxx"
WHATSAPP_BUSINESS_ACCOUNT_ID="xxx"
WHATSAPP_VERIFY_TOKEN="xxx"

# ─── SMS (MSG91) ─────────────────────────────────────────────────────────────
MSG91_AUTH_KEY="xxx"
MSG91_SENDER_ID="ATLAS"
MSG91_OTP_TEMPLATE_ID="xxx"

# ─── Aggregators ─────────────────────────────────────────────────────────────
ZOMATO_CLIENT_ID="xxx"
ZOMATO_CLIENT_SECRET="xxx"
SWIGGY_CLIENT_ID="xxx"
SWIGGY_CLIENT_SECRET="xxx"

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN="https://xxx@sentry.io/xxx"
