{
  "name": "@atlas/api",
  "version": "0.0.1",
  "private": true,
  "description": "Atlas REST API — Fastify, TypeScript, Prisma",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results.xml",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@atlas/db": "workspace:*",
    "@atlas/types": "workspace:*",
    "@atlas/utils": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.1",
    "eventemitter3": "^5.0.1",
    "fastify": "^4.28.1",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@atlas/config": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.1",
    "rimraf": "^5.0.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
