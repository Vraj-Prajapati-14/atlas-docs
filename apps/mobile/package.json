  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@types/react": "^18.3.5",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.5.4",
    "rimraf": "^5.0.10"
