# ─────────────────────────────────────────────────────────────────────────────
# Atlas Environment Variables — Template
# Copy to .env and fill in real values.
# NEVER commit .env files to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
# development | staging | production

# ── Database (Neon.tech or any PostgreSQL) ───────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/atlas_dev?sslmode=require"
# Use the pooled connection URL from Neon for the app
DIRECT_URL="postgresql://user:password@host:5432/atlas_dev?sslmode=require"
# Use the direct (non-pooled) URL for Prisma migrations

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-256-bit-secret-minimum-32-chars"
JWT_EXPIRES_IN="8h"
REFRESH_TOKEN_EXPIRES_IN="30d"
BCRYPT_ROUNDS=12

# ── API Server ───────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info
# fatal | error | warn | info | debug | trace
CORS_ORIGIN="http://localhost:3000"
# Comma-separated for multiple origins: http://localhost:3000,https://app.atlas-app.in

# ── Redis (optional for MVP, used for rate limiting + caching) ───────────────
REDIS_URL="redis://localhost:6379"

# ── Razorpay (Payments) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_TOKEN="EAAxxxxxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="xxxxxxxxxxxx"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_BUSINESS_ACCOUNT_ID="xxxxxxxxxxxx"

# ── MSG91 (SMS / OTP) ────────────────────────────────────────────────────────
MSG91_AUTH_KEY="xxxxxxxxxxxxxxxxxxxxxxxx"
MSG91_TEMPLATE_ID_OTP="xxxxxxxxxxxxxxxxxxxxxxxx"
MSG91_SENDER_ID="ATLAS"

# ── Zomato (Partner API) ─────────────────────────────────────────────────────
ZOMATO_API_KEY=""
ZOMATO_RESTAURANT_ID=""

# ── Swiggy (Partner API) ─────────────────────────────────────────────────────
SWIGGY_API_KEY=""
SWIGGY_RESTAURANT_ID=""

# ── Next.js Web App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="Atlas"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ── Sentry (Error tracking) ──────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
