{
  "name": "atlas",
  "version": "0.0.1",
  "private": true,
  "description": "Atlas Restaurant ERP — monorepo root",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "dev:api": "turbo dev --filter=@atlas/api",
    "dev:web": "turbo dev --filter=@atlas/web",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:ci": "turbo test:ci",
    "clean": "turbo clean && rimraf node_modules",
    "db:generate": "turbo db:generate --filter=@atlas/db",
    "db:migrate:dev": "turbo db:migrate:dev --filter=@atlas/db",
    "db:migrate:deploy": "turbo db:migrate:deploy --filter=@atlas/db",
    "db:seed": "turbo db:seed --filter=@atlas/db",
    "db:studio": "turbo db:studio --filter=@atlas/db",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.10",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
